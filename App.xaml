<Application
    x:Class="levyke.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <!-- Монотонная цветовая схема -->
            <Color x:Key="AccentColor">#FF1A8C</Color>
            <Color x:Key="BackgroundColor">#000000</Color>
            <Color x:Key="SurfaceColor">#1A1A1A</Color>
            <Color x:Key="TextColor">#FFFFFF</Color>
            <Color x:Key="TextSecondaryColor">#888888</Color>

            <!-- Кисти -->
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
            <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
            <SolidColorBrush x:Key="MiniPlayerBackgroundBrush" Color="#CC000000"/>
            <SolidColorBrush x:Key="PlaybackControlBrush" Color="{StaticResource AccentColor}"/>
            <SolidColorBrush x:Key="PlaybackControlForegroundBrush" Color="White"/>
            <SolidColorBrush x:Key="AppTitleBrush" Color="{StaticResource AccentColor}"/>
            <SolidColorBrush x:Key="MainBackgroundBrush" Color="{StaticResource BackgroundColor}"/>

            <!-- Заголовки -->
            <Style x:Key="TitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="42"/>
                <Setter Property="FontWeight" Value="Light"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="FontFamily" Value="Segoe UI Light"/>
            </Style>

            <!-- Обычный текст -->
            <Style x:Key="BodyTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            </Style>

            <!-- Вторичный текст -->
            <Style x:Key="SecondaryTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            </Style>

            <!-- Кнопки -->
            <Style x:Key="FlatButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Padding" Value="20,10"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>