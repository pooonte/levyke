<Page
    x:Class="levyke.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:levyke"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource MainBackgroundBrush}">

    <Page.Resources>
        <DataTemplate x:Key="TrackDialogTemplate">
            <Grid Height="50" Margin="0,4,16,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Номер трека -->
                <Border Grid.Column="0"
                        Width="30"
                        Height="30"
                        CornerRadius="15"
                        Background="{StaticResource PlaybackControlBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding TrackNumber}" 
                               Foreground="White" 
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Название трека -->
                <StackPanel Grid.Column="1" 
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}" 
                               Foreground="White" 
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Artist}" 
                               Foreground="{StaticResource PlaybackControlBrush}"
                               FontSize="11"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Длительность -->
                <TextBlock Grid.Column="2" 
                           Text="{Binding DurationString}" 
                           Foreground="Gray"
                           FontSize="12"
                           Margin="0,0,0,0"
                           VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <Grid x:Name="MainContent">
            <Grid.RowDefinitions>
                <RowDefinition Height="9*"/>
                <RowDefinition Height="55*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="levyke" x:Name="MainName" 
                       Foreground="{StaticResource AppTitleBrush}" 
                       Margin="16,16,0,0" FontSize="24" 
                       HorizontalAlignment="Left" VerticalAlignment="Top"/>

            <Pivot Margin="0,53,0,0" Grid.RowSpan="2" x:Name="MainPivot">

                <!-- МЕДИАТЕКА -->
                <PivotItem Header="Медиатека" FontSize="22">
                    <ListView x:Name="TracksList" 
                              ItemClick="Track_ItemClick" 
                              IsItemClickEnabled="True"
                              Background="Transparent" 
                              Margin="-12,0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="40" Margin="0,4">
                                    <TextBlock VerticalAlignment="Stretch"
                                               TextWrapping="Wrap"
                                               MaxWidth="280">
                                        <Run Text="{Binding Title}"
                                             Foreground="White"
                                             FontSize="14"/>
                                        <LineBreak />
                                        <Run Text="{Binding Artist}"
                                             Foreground="White"
                                             FontSize="12"/>
                                        <Run Text=" --- "
                                             Foreground="White"
                                             FontSize="12"/>
                                        <Run Text="{Binding Album}"
                                             Foreground="White"
                                             FontSize="12"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </PivotItem>

                <!-- ИСПОЛНИТЕЛИ -->
                <PivotItem Header="Исполнители" FontSize="22">
                    <ListView x:Name="ArtistsList" 
                              ItemClick="Artist_ItemClick" 
                              IsItemClickEnabled="True" 
                              Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="16,8">
                                    <TextBlock Text="{Binding Name}" 
                                               Foreground="White" 
                                               FontSize="16"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text=" (" 
                                               Foreground="{StaticResource PlaybackControlBrush}"
                                               FontSize="14"
                                               Margin="4,0,0,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding TrackCount}" 
                                               Foreground="{StaticResource PlaybackControlBrush}"
                                               FontSize="14"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text=")" 
                                               Foreground="{StaticResource PlaybackControlBrush}"
                                               FontSize="14"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </PivotItem>

                <!-- АЛЬБОМЫ -->
                <PivotItem Header="Альбомы" FontSize="22">
                    <ListView x:Name="AlbumsList" 
                              ItemClick="Album_ItemClick" 
                              IsItemClickEnabled="True" 
                              Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="16,8">
                                    <TextBlock Text="{Binding Name}" 
                                               Foreground="White" 
                                               FontSize="16"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding Artist}" 
                                                   Foreground="{StaticResource PlaybackControlBrush}"
                                                   FontSize="12"/>
                                        <TextBlock Text=" — " 
                                                   Foreground="{StaticResource PlaybackControlBrush}"
                                                   FontSize="12"/>
                                        <TextBlock Text="{Binding TrackCount}" 
                                                   Foreground="{StaticResource PlaybackControlBrush}"
                                                   FontSize="12"/>
                                        <TextBlock Text=" треков" 
                                                   Foreground="{StaticResource PlaybackControlBrush}"
                                                   FontSize="12"
                                                   Margin="2,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </PivotItem>

                <!-- ПОИСК -->
                <PivotItem Header="Поиск" FontSize="22" Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBox x:Name="SearchBox"
                                 Grid.Row="0"
                                 Margin="16,16,16,10"
                                 PlaceholderText="Введите название трека, исполнителя или альбома..."
                                 TextChanged="SearchBox_TextChanged"
                                 Background="{StaticResource MiniPlayerBackgroundBrush}"
                                 Foreground="White"
                                 BorderBrush="{StaticResource PlaybackControlBrush}"
                                 BorderThickness="2"
                                 FontSize="16"
                                 Padding="12,0,12,0"/>

                        <Grid Grid.Row="1">
                            <ListView x:Name="SearchResultsList"
                                      ItemClick="SearchResult_ItemClick"
                                      IsItemClickEnabled="True"
                                      Background="Transparent"
                                      Margin="0,8,0,0"
                                      Visibility="Collapsed">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="40" Margin="0,4">
                                            <TextBlock VerticalAlignment="Stretch"
                                                       TextWrapping="Wrap"
                                                       MaxWidth="280">
                                                <Run Text="{Binding Title}"
                                                     Foreground="White"
                                                     FontSize="14"/>
                                                <LineBreak />
                                                <Run Text="{Binding Artist}"
                                                     Foreground="White"
                                                     FontSize="12"/>
                                                <Run Text=" --- "
                                                     Foreground="White"
                                                     FontSize="12"/>
                                                <Run Text="{Binding Album}"
                                                     Foreground="White"
                                                     FontSize="12"/>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <StackPanel x:Name="EmptyStatePanel"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Visibility="Visible">
                                <Image x:Name="SearchImage1"
                                       Source="ms-appx:///Assets/intelligence.png"
                                       Width="120" Height="68"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                    <Image.RenderTransform>
                                        <RotateTransform x:Name="Image1Rotation" Angle="0"/>
                                    </Image.RenderTransform>
                                </Image>
                                <TextBlock x:Name="SearchBoxText"
                                           Text="Начните вводить текст для поиска" 
                                           Foreground="{StaticResource AppTitleBrush}"
                                           FontSize="16"
                                           Margin="0,20,0,0"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </PivotItem>

                <!-- НАСТРОЙКИ -->
                <PivotItem Header="Настройки">
                    <StackPanel Margin="16,16,16,0">
                        <TextBlock Text="Выберите тему:"
                                   Foreground="White"
                                   Margin="0,0,0,8" 
                                   FontSize="16"/>
                        <ComboBox x:Name="ThemeSelector"
                                  SelectionChanged="ThemeSelector_SelectionChanged"
                                  Foreground="White"
                                  Background="{StaticResource MiniPlayerBackgroundBrush}" 
                                  Width="222"
                                  Margin="0,0,0,20"
                                  Padding="8,5"/>
                        <Button x:Name="RefreshLibraryButton"
                                Content="⟳ Обновить библиотеку"
                                Click="RefreshLibraryButton_Click"
                                Height="45"
                                Background="{StaticResource MiniPlayerBackgroundBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="16"/>
                        <TextBlock Text="При обновлении библиотеки приложение пересканирует все папки и найдет новые треки. Это может занять некоторое время."
                                   Foreground="#AAAAAA"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </PivotItem>
            </Pivot>

            <!-- МИНИ-ПЛЕЕР -->
            <Grid x:Name="MiniPlayerPanel"
                  VerticalAlignment="Bottom"
                  Background="{StaticResource MiniPlayerBackgroundBrush}"
                  Height="60"
                  Visibility="Collapsed" 
                  Grid.Row="1">
                <Button x:Name="OpenPlayerButton"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="250"
                        Click="OpenPlayerButton_Click">
                    <StackPanel Orientation="Horizontal" Margin="12,0">
                        <Image x:Name="MiniAlbumArt" Width="40" Height="40" Stretch="UniformToFill"/>
                        <StackPanel Margin="10,0,0,0" 
                                    VerticalAlignment="Stretch" 
                                    HorizontalAlignment="Left">
                            <TextBlock x:Name="MiniTrackTitle" 
                                       Foreground="White" 
                                       FontSize="14" 
                                       MaxWidth="150" 
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="MiniTrackArtist" 
                                       Foreground="White" 
                                       FontSize="12" 
                                       MaxWidth="150" 
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
                <Button x:Name="MiniPlayButton"
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0"
                        Background="{StaticResource PlaybackControlBrush}"
                        BorderThickness="0"
                        Click="MiniPlayButton_Click">
                    <Image x:Name="MiniPlayPauseIcon" Width="24" Height="24"/>
                </Button>
            </Grid>
        </Grid>

        <!-- ПОЛНОЭКРАННАЯ ПАНЕЛЬ ДЛЯ ТРЕКОВ -->
        <Grid x:Name="FullScreenTracksPanel"
              Background="{StaticResource MainBackgroundBrush}"
              Visibility="Collapsed"
              Canvas.ZIndex="200">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ШАПКА -->
            <Grid Grid.Row="0" 
                  Background="{StaticResource MiniPlayerBackgroundBrush}"
                  Height="80"
                  Padding="16">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Кнопка назад -->
                <Button x:Name="CloseTracksPanelButton"
                        Grid.Column="0"
                        Width="40"
                        Height="40"
                        Background="Transparent"
                        Click="CloseTracksPanelButton_Click">
                    <TextBlock Text="←" 
                               FontSize="24" 
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Button>

                <!-- Заголовок -->
                <TextBlock x:Name="TracksPanelTitle"
                           Grid.Column="1"
                           Text="Загрузка..."
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>

            <!-- СПИСОК ТРЕКОВ -->
            <ListView x:Name="FullScreenTracksList"
                      Grid.Row="1"
                      ItemClick="FullScreenTrack_ItemClick"
                      IsItemClickEnabled="True"
                      Background="Transparent"
                      Margin="0,8,0,0"
                      ItemTemplate="{StaticResource TrackDialogTemplate}">
            </ListView>

            <!-- НИЖНЯЯ ПАНЕЛЬ (МИНИ-ПЛЕЕР) -->
            <Grid Grid.Row="2"
                  Background="{StaticResource MiniPlayerBackgroundBrush}"
                  Height="60">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Обложка -->
                <Image Grid.Column="0"
                       x:Name="FullScreenMiniAlbumArt"
                       Width="40" Height="40"
                       Margin="12,0,0,0"
                       Stretch="UniformToFill"/>

                <!-- Информация -->
                <StackPanel Grid.Column="1" 
                            Margin="10,0,0,0" 
                            VerticalAlignment="Center">
                    <TextBlock x:Name="FullScreenMiniTitle" 
                               Foreground="White" 
                               FontSize="14" 
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="FullScreenMiniArtist" 
                               Foreground="White" 
                               FontSize="12" 
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Кнопки -->
                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">
                    <Button x:Name="FullScreenPrevButton"
                            Width="40"
                            Height="40"
                            Background="Transparent"
                            Click="PrevButton_Click">
                        <TextBlock Text="⏮" FontSize="20" Foreground="White"/>
                    </Button>
                    <Button x:Name="FullScreenPlayButton"
                            Width="40"
                            Height="40"
                            Background="Transparent"
                            Click="MiniPlayButton_Click">
                        <Image x:Name="FullScreenPlayIcon" Width="20" Height="20"/>
                    </Button>
                    <Button x:Name="FullScreenNextButton"
                            Width="40"
                            Height="40"
                            Background="Transparent"
                            Click="NextButton_Click">
                        <TextBlock Text="⏭" FontSize="20" Foreground="White"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ПОЛНОЭКРАННЫЙ ПЛЕЕР -->
        <Grid x:Name="FullPlayerOverlay"
              Visibility="Collapsed"
              Background="{StaticResource MainBackgroundBrush}"
              Loaded="FullPlayerOverlay_Loaded"
              Canvas.ZIndex="100">

            <Image x:Name="FullAlbumArt"
                   Width="140"
                   Height="140"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Bottom"
                   Margin="20,0,0,120"/>

            <Button x:Name="BackButton"
                    Content="←"
                    FontSize="24"
                    Width="50"
                    Height="50"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="16,16,0,0"
                    Background="Transparent"
                    Foreground="White"
                    Click="BackButton_Click"/>

            <TextBlock x:Name="FullTrackTitle"
                       Foreground="White"
                       FontSize="24"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Margin="170,0,0,200"
                       MaxWidth="300"
                       TextWrapping="Wrap"/>

            <TextBlock x:Name="FullTrackArtist"
                       Foreground="White"
                       FontSize="18"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       Margin="170,0,0,177"
                       MaxWidth="300"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="15,0,0,60">
                <TextBlock x:Name="CurrentTimeText" 
                           Text="0:00" 
                           Foreground="White" 
                           Margin="0,0,10,0"/>
                <Slider x:Name="ProgressSlider"
                        Width="250"
                        Height="30"
                        Foreground="{StaticResource AppTitleBrush}"
                        ManipulationMode="TranslateX"
                        ManipulationStarted="ProgressSlider_ManipulationStarted"
                        ManipulationCompleted="ProgressSlider_ManipulationCompleted" />
                <TextBlock x:Name="TotalTimeText" 
                           Text="0:00" 
                           Foreground="White" 
                           Margin="10,0,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="10,0,0,10">
                <Button x:Name="PrevButton" 
                        Click="PrevButton_Click" 
                        Background="Transparent" 
                        Foreground="{StaticResource AppTitleBrush}" 
                        FontSize="24" >
                    <Image x:Name="PrevButtonImage" Width="24" Height="24" Source="ms-appx:///Assets/prev.png"/>
                </Button>
                <Button x:Name="PlayPauseButton" 
                        Click="PlayPauseButton_Click"
                        Background="Transparent"
                        Foreground="{StaticResource AppTitleBrush}"
                        FontSize="24">
                    <Image x:Name="FullPlayPauseIcon" Width="24" Height="24" />
                </Button>
                <Button x:Name="NextButton" 
                        Click="NextButton_Click" 
                        Background="Transparent" 
                        Foreground="{StaticResource AppTitleBrush}" 
                        FontSize="24">
                    <Image x:Name="NextButtonImage" Width="24" Height="24" Source="ms-appx:///Assets/next.png"/>
                </Button>
                <Slider x:Name="VolumeSlider"
                       Margin="10,0,0,0"
                       Width="150"
                       Minimum="0"
                       Maximum="100"
                       Value="100"
                       Foreground="{StaticResource AppTitleBrush}"
                       ValueChanged="VolumeSlider_ValueChanged"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>