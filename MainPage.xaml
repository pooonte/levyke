<Page
    x:Class="levyke.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:levyke"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource MainBackgroundBrush}">

    <Grid>
        <Grid x:Name="MainContent">
            <Grid.RowDefinitions>
                <RowDefinition Height="9*"/>
                <RowDefinition Height="55*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="levyke" x:Name="MainName" Foreground="{StaticResource AppTitleBrush}" Margin="16,16,0,0" FontSize="24" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Pivot Margin="0,53,0,0" Grid.RowSpan="2" x:Name="MainPivot">
                <PivotItem Header="Медиатека" FontSize="22">
                    <ListView x:Name="TracksList" 
                              ItemClick="Track_ItemClick" 
                              IsItemClickEnabled="True"
                              Background="Transparent" Margin="-12,0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="40" Margin="0,4">
                                    <TextBlock VerticalAlignment="Stretch"
                                               TextWrapping="Wrap"
                                               MaxWidth="280">
                                        <Run Text="{Binding Title}"
                                             Foreground="White"
                                             FontSize="14"/>
                                        <LineBreak />
                                        <Run Text="{Binding Artist}"
                                             Foreground="White"
                                             FontSize="12"/>
                                        <Run Text=" --- "
                                             Foreground="White"
                                             FontSize="12"/>
                                        <Run Text="{Binding Album}"
                                             Foreground="White"
                                             FontSize="12"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </PivotItem>

                <PivotItem Header="Исполнители" FontSize="22">
                    <Grid>
                        <ListView x:Name="ArtistsList" 
                  ItemClick="Artist_ItemClick" 
                  IsItemClickEnabled="True" 
                  Background="Transparent"
                  Visibility="Visible">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="16,8">
                                        <TextBlock Text="{Binding Name}" 
                                   Foreground="White" 
                                   FontSize="16"
                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=" (" 
                                   Foreground="{StaticResource PlaybackControlBrush}"
                                   FontSize="14"
                                   Margin="4,0,0,0"
                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding TrackCount}" 
                                   Foreground="{StaticResource PlaybackControlBrush}"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=")" 
                                   Foreground="{StaticResource PlaybackControlBrush}"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Grid x:Name="ArtistSongsPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" 
                  Background="{StaticResource MiniPlayerBackgroundBrush}"
                  Height="60"
                  Padding="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="BackToArtistsButton"
                        Grid.Column="0"
                        Width="40"
                        Height="40"
                        Background="Transparent"
                        Click="BackToArtistsButton_Click">
                                    <TextBlock Text="←" 
                               FontSize="24" 
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                                </Button>

                                <TextBlock Grid.Column="1"
                           x:Name="SelectedArtistName"
                           Text="Исполнитель"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
                            </Grid>

                            <ListView x:Name="ArtistSongsList"
                      Grid.Row="1"
                      ItemClick="ArtistSong_ItemClick"
                      IsItemClickEnabled="True"
                      Background="Transparent"
                      Margin="0,8,0,0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="50" Margin="16,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" 
                                       Text="{Binding TrackNumber}" 
                                       Foreground="Gray"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>

                                            <StackPanel Grid.Column="1" 
                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" 
                                           Foreground="White" 
                                           FontSize="16"
                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Album}" 
                                           Foreground="Gray" 
                                           FontSize="12"
                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="2" 
                                       Text="{Binding DurationString}" 
                                       Foreground="Gray"
                                       FontSize="12"
                                       Margin="0,0,16,0"
                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </PivotItem>

                <PivotItem Header="Альбомы" FontSize="22">
                    <Grid>
                        <ListView x:Name="AlbumsList" 
                  ItemClick="Album_ItemClick" 
                  IsItemClickEnabled="True" 
                  Background="Transparent"
                  Visibility="Visible">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="16,8">
                                        <TextBlock Text="{Binding Name}" 
                                   Foreground="White" 
                                   FontSize="16"
                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding Artist}" 
                                       Foreground="{StaticResource PlaybackControlBrush}"
                                       FontSize="12"/>
                                            <TextBlock Text=" — " 
                                       Foreground="{StaticResource PlaybackControlBrush}"
                                       FontSize="12"/>
                                            <TextBlock Text="{Binding TrackCount}" 
                                       Foreground="{StaticResource PlaybackControlBrush}"
                                       FontSize="12"/>
                                            <TextBlock Text=" треков" 
                                       Foreground="{StaticResource PlaybackControlBrush}"
                                       FontSize="12"
                                       Margin="2,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Grid x:Name="AlbumSongsPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" 
                  Background="{StaticResource MiniPlayerBackgroundBrush}"
                  Height="60"
                  Padding="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="BackToAlbumsButton"
                        Grid.Column="0"
                        Width="40"
                        Height="40"
                        Background="Transparent"
                        Click="BackToAlbumsButton_Click">
                                    <TextBlock Text="←" 
                               FontSize="24" 
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                                </Button>

                                <TextBlock Grid.Column="1"
                           x:Name="SelectedAlbumName"
                           Text="Альбом"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
                            </Grid>

                            <ListView x:Name="AlbumSongsList"
                      Grid.Row="1"
                      ItemClick="AlbumSong_ItemClick"
                      IsItemClickEnabled="True"
                      Background="Transparent"
                      Margin="0,8,0,0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="50" Margin="16,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" 
                                       Text="{Binding TrackNumber}" 
                                       Foreground="Gray"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>

                                            <StackPanel Grid.Column="1" 
                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" 
                                           Foreground="White" 
                                           FontSize="16"
                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Artist}" 
                                           Foreground="Gray" 
                                           FontSize="12"
                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="2" 
                                       Text="{Binding DurationString}" 
                                       Foreground="Gray"
                                       FontSize="12"
                                       Margin="0,0,16,0"
                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </PivotItem>

                <PivotItem Header="Онлайн" FontSize="22">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" 
                    HorizontalAlignment="Center" >
                            <TextBlock Text="Нужны онлайн функции?" 
                       Foreground="White" 
                       FontSize="22"/>
                            <Button Content="Да" 
                    Click="OpenOnlinePage_Click" 
                    Height="45" 
                    Width="260"
                    Background="{StaticResource PlaybackControlBrush}" 
                    Foreground="White"/>
                        </StackPanel>
                    </Grid>
                </PivotItem>
                
                <PivotItem Header="Поиск" FontSize="22" Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBox x:Name="SearchBox"
                                 Grid.Row="0"
                                 Margin="16,16,16,10"
                                 PlaceholderText="Введите название трека, исполнителя или альбома..."
                                 TextChanged="SearchBox_TextChanged"
                                 Background="{StaticResource MiniPlayerBackgroundBrush}"
                                 Foreground="White"
                                 BorderBrush="{StaticResource PlaybackControlBrush}"
                                 BorderThickness="2"
                                 FontSize="16"
                                 Padding="12,0,12,0"/>

                        <Grid Grid.Row="1">
                            <ListView x:Name="SearchResultsList"
                                      ItemClick="SearchResult_ItemClick"
                                      IsItemClickEnabled="True"
                                      Background="Transparent"
                                      Margin="0,8,0,0"
                                      Visibility="Collapsed">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="40" Margin="0,4">
                                            <TextBlock VerticalAlignment="Stretch"
                                                       TextWrapping="Wrap"
                                                       MaxWidth="280">
                                                <Run Text="{Binding Title}"
                                                     Foreground="White"
                                                     FontSize="14"/>
                                                <LineBreak />
                                                <Run Text="{Binding Artist}"
                                                     Foreground="White"
                                                     FontSize="12"/>
                                                <Run Text=" --- "
                                                     Foreground="White"
                                                     FontSize="12"/>
                                                <Run Text="{Binding Album}"
                                                     Foreground="White"
                                                     FontSize="12"/>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <StackPanel x:Name="EmptyStatePanel"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Visibility="Visible">
                                <Image x:Name="SearchImage1"
                                       Source="ms-appx:///Assets/intelligence.png"
                                       Width="120" Height="68"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Visible">
                                    <Image.RenderTransform>
                                        <RotateTransform x:Name="Image1Rotation" Angle="0"/>
                                    </Image.RenderTransform>
                                </Image>
                                <TextBlock Text="Начните вводить текст для поиска" 
                                           Foreground="{StaticResource AppTitleBrush}"
                                           x:Name="SearchBoxText"
                                           FontSize="16"
                                           Margin="0,20,0,0"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </PivotItem>

                <PivotItem Header="Настройки">
                    <StackPanel>
                        <TextBlock Text="Выберите тему:"
                                   Foreground="White"
                                   Margin="15,15,100,15" Height="24"/>
                        <ComboBox x:Name="ThemeSelector"
                                  SelectionChanged="ThemeSelector_SelectionChanged"
                                  Foreground="White"
                                  Background="{StaticResource MiniPlayerBackgroundBrush}" Width="222"
                                  Margin="14,0,0,0"/>
                        <Button x:Name="RefreshLibraryButton"
                                Content="⟳ Обновить библиотеку"
                                Click="RefreshLibraryButton_Click"
                                Margin="15,30,15,0"
                                Height="45"
                                Background="{StaticResource MiniPlayerBackgroundBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="16"/>

                        <TextBlock Text="При обновлении библиотеки приложение пересканирует все папки и найдет новые треки. Это может занять некоторое время."
                   Foreground="#AAAAAA"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="15,10,15,0"/>
                    </StackPanel>
                </PivotItem>
            </Pivot>
            <Grid x:Name="MiniPlayerPanel"
                  VerticalAlignment="Bottom"
                  Background="{StaticResource MiniPlayerBackgroundBrush}"
                  Height="60"
                  Visibility="Collapsed" Grid.Row="1">
                <Button x:Name="OpenPlayerButton"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="250"
                        Click="OpenPlayerButton_Click">
                    <StackPanel Orientation="Horizontal" Margin="12,0">
                        <Image x:Name="MiniAlbumArt" Width="40" Height="40" Stretch="UniformToFill"/>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Stretch" HorizontalAlignment="Left">
                            <TextBlock x:Name="MiniTrackTitle" Foreground="White" FontSize="14" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="MiniTrackArtist" Foreground="White" FontSize="12" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
                <Button x:Name="MiniPlayButton"
                        FontSize="18"
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0"
                        Background="{StaticResource PlaybackControlBrush}"
                        Foreground="{StaticResource PlaybackControlForegroundBrush}"
                        Click="MiniPlayButton_Click">
                    <Image x:Name="MiniPlayPauseIcon" Width="24" Height="24"/>
                </Button>
            </Grid>
        </Grid>

        <Grid x:Name="FullPlayerOverlay"
      Visibility="Collapsed"
      Background="#1a1a1a"
      Loaded="FullPlayerOverlay_Loaded"
      Canvas.ZIndex="100">

            <!-- Фон с размытой обложкой (опционально) -->
            <Image x:Name="BackgroundAlbumArt"
           Stretch="UniformToFill"
           Opacity="0.3"/>

            <!-- Кнопка Назад -->
            <Button x:Name="BackButton"
            Content="←"
            FontSize="24"
            Width="50"
            Height="50"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="20,20,0,0"
            Background="Transparent"
            Foreground="White"
            Click="BackButton_Click"/>

            <!-- Заголовок NOW PLAYING -->
            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,30,0,0">
                <TextBlock Text="NOW PLAYING"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,20,0"/>
                <TextBlock Text="QUEUE"
                   Foreground="#888888"
                   FontSize="20"
                   FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Обложка альбома с белой рамкой -->
            <Grid HorizontalAlignment="Center" 
          VerticalAlignment="Center"
          Margin="0,-40,0,0">
                <Border BorderBrush="White" 
                BorderThickness="2" 
                Width="340" 
                Height="340">
                    <Image x:Name="FullAlbumArt"
                   Width="336"
                   Height="336"
                   Stretch="UniformToFill"/>
                </Border>

                <!-- Текст поверх обложки (внизу слева) -->
                <Grid VerticalAlignment="Bottom" 
              HorizontalAlignment="Left" 
              Background="White" 
              Margin="20,0,0,20"
              Padding="15,12"
              MaxWidth="280">
                    <StackPanel>
                        <TextBlock x:Name="FullTrackTitle" 
                           Text="I Follow Rivers (The Magician Remix)" 
                           Foreground="Black" 
                           FontSize="20" 
                           FontFamily="Segoe UI Light"
                           TextWrapping="Wrap"
                           MaxWidth="250"/>
                        <TextBlock x:Name="FullTrackArtist" 
                           Text="Lykke Li" 
                           Foreground="#666666" 
                           FontSize="14" 
                           FontFamily="Segoe UI Light"
                           Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Прогресс бар -->
            <Grid VerticalAlignment="Bottom" 
          Margin="40,0,40,150">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="CurrentTimeText" 
                   Text="1:47" 
                   Foreground="#aaaaaa" 
                   FontSize="12" 
                   VerticalAlignment="Center"/>
                <Slider x:Name="ProgressSlider"
                Grid.Column="1"
                Margin="20,0"
                Height="4"
                Foreground="White"
                Background="#444444"
                ManipulationMode="TranslateX"
                ManipulationStarted="ProgressSlider_ManipulationStarted"
                ManipulationCompleted="ProgressSlider_ManipulationCompleted"/>
                <TextBlock x:Name="TotalTimeText" 
                   Grid.Column="2"
                   Text="4:43" 
                   Foreground="#aaaaaa" 
                   FontSize="12" 
                   VerticalAlignment="Center"/>
            </Grid>

            <!-- Кнопки управления -->
            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,70">

                <!-- Shuffle -->
                <Button x:Name="ShuffleButton"
                Background="Transparent"
                Width="50"
                Height="50"
                Margin="10,0">
                    <SymbolIcon Symbol="Shuffle" 
                        Foreground="White" 
                        Width="24" 
                        Height="24"/>
                </Button>

                <!-- Previous -->
                <Button x:Name="PrevButton"
                Click="PrevButton_Click"
                Background="Transparent"
                Width="60"
                Height="60"
                Margin="15,0">
                    <Border BorderBrush="White" 
                    BorderThickness="1.5" 
                    CornerRadius="30" 
                    Width="56" 
                    Height="56">
                        <SymbolIcon Symbol="Previous" 
                            Foreground="White" 
                            Width="22" 
                            Height="22"/>
                    </Border>
                </Button>

                <!-- Play/Pause (большая) -->
                <Button x:Name="PlayPauseButton"
                Click="PlayPauseButton_Click"
                Background="Transparent"
                Width="80"
                Height="80"
                Margin="15,0">
                    <Border BorderBrush="White" 
                    BorderThickness="2" 
                    CornerRadius="40" 
                    Width="76" 
                    Height="76">
                        <SymbolIcon x:Name="FullPlayPauseIcon" 
                            Symbol="Play" 
                            Foreground="White" 
                            Width="32" 
                            Height="32"/>
                    </Border>
                </Button>

                <!-- Next -->
                <Button x:Name="NextButton"
                Click="NextButton_Click"
                Background="Transparent"
                Width="60"
                Height="60"
                Margin="15,0">
                    <Border BorderBrush="White" 
                    BorderThickness="1.5" 
                    CornerRadius="30" 
                    Width="56" 
                    Height="56">
                        <SymbolIcon Symbol="Next" 
                            Foreground="White" 
                            Width="22" 
                            Height="22"/>
                    </Border>
                </Button>

                <!-- Repeat -->
                <Button x:Name="RepeatButton"
                Background="Transparent"
                Width="50"
                Height="50"
                Margin="10,0">
                    <SymbolIcon Symbol="RepeatAll" 
                        Foreground="White" 
                        Width="24" 
                        Height="24"/>
                </Button>
                <Slider x:Name="VolumeSlider"
        Margin="20,10,0,0"
        Width="120"
        Height="40"
        Minimum="0"
        Maximum="100"
        Value="100"
        Foreground="{StaticResource AppTitleBrush}"
        Background="#444444"
        VerticalAlignment="Center"
        ValueChanged="VolumeSlider_ValueChanged"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>