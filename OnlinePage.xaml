<Page
    x:Class="levyke.Views.OnlinePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource MainBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Grid Grid.Row="0" 
              Background="{StaticResource MiniPlayerBackgroundBrush}"
              Height="60"
              Padding="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton"
                    Grid.Column="0"
                    Width="40"
                    Height="40"
                    Background="Transparent"
                    Click="BackButton_Click">
                <TextBlock Text="←" FontSize="24" Foreground="White"/>
            </Button>

            <TextBlock Grid.Column="1"
                       Text="Стриминг"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"/>
        </Grid>

        <!-- Список -->
        <ListView x:Name="OnlineTracksList"
                  Grid.Row="1"
                  ItemClick="OnlineTrack_ItemClick"
                  IsItemClickEnabled="True"
                  Background="Transparent"
                  Margin="0,8,0,0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Height="50" Margin="16,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Name}" 
                                       Foreground="White" 
                                       FontSize="16"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Folder}" 
                                       Foreground="Gray" 
                                       FontSize="12"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1" 
                                   Text="🌐" 
                                   Foreground="{StaticResource PlaybackControlBrush}"
                                   FontSize="16"
                                   Margin="0,0,16,0"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Плеер -->
        <Grid Grid.Row="2"
              x:Name="OnlinePlayer"
              Background="{StaticResource MiniPlayerBackgroundBrush}"
              Height="60"
              Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" 
                        Margin="16,0" 
                        VerticalAlignment="Center">
                <TextBlock x:Name="NowPlayingTitle" 
                           Foreground="White" 
                           FontSize="14" 
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="NowPlayingArtist" 
                           Foreground="Gray" 
                           FontSize="12" 
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <Button Grid.Column="1"
                    x:Name="OnlinePlayPauseButton"
                    Width="40"
                    Height="40"
                    Margin="0,0,16,0"
                    Background="Transparent"
                    Click="OnlinePlayPauseButton_Click">
                <Image x:Name="OnlinePlayPauseIcon" Width="20" Height="20"/>
            </Button>
        </Grid>
    </Grid>
</Page>